{
  "name": "evandroswk/plugnotas",
  "description": "Pacote para utilização do Plugnotas em PHP",
  "type": "library",
  "keywords": [
    "tecnospeed",
    "plugnotas",
    "documentos fiscais",
    "nfse"
  ],
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "EvandroSwk\\Plugnotas\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EvandroSwk\\Plugnotas\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "require": {
    "php": "^7.4|^8.1",
    "respect/validation": "^2.2",
    "ferfabricio/hydrator": "^3.0",
    "guzzlehttp/guzzle": "^7.3",
    "maciejczyzewski/bottomline": "^0.2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  }
}
